<Page x:Class="SFTracker.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="Main">

    <Grid Margin="16,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Margin="0,0,0,8">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="SF Tracker" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4"
                                Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding IsPremium, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="PRO" FontSize="9" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                Visibility="{Binding Username, Converter={StaticResource NotEmptyToVisibility}}">
                        <TextBlock Text="{Binding Username}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text=" · " FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Visibility="{Binding StorageInfo, Converter={StaticResource NotEmptyToVisibility}}"/>
                        <TextBlock Text="{Binding StorageInfo}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Visibility="{Binding StorageInfo, Converter={StaticResource NotEmptyToVisibility}}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButton}" Command="{Binding OpenSaveFolderCommand}"
                            ToolTip="Відкрити папку сейвів">📁</Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding RefreshCommand}"
                            ToolTip="Оновити" Margin="4,0,0,0">↺</Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding LogoutCommand}"
                            ToolTip="Вийти" Margin="4,0,0,0">⏻</Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- World selector -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="СВІТ" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding Worlds}"
                          SelectedItem="{Binding SelectedWorld}"
                          DisplayMemberPath="Name"/>
            </StackPanel>
        </Border>

        <!-- Save info: Local vs Cloud -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Ellipse Width="6" Height="6" Fill="#44FF6B35" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ЛОКАЛЬНО" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LocalSaveInfo}" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="#22FFFFFF" Width="1"/>

                <StackPanel Grid.Column="2" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Ellipse Width="6" Height="6" Fill="#4400BFFF" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ХМАРА" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding CloudSaveInfo}" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sync button -->
        <Border Grid.Row="3" Style="{StaticResource GlassCard}" Margin="0,0,0,8">
            <StackPanel>
                <!-- Big Sync -->
                <Button Content="{Binding SyncDirection}"
                        Command="{Binding SyncCommand}"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="15" Padding="0,14"
                        HorizontalAlignment="Stretch"/>

                <!-- Progress -->
                <ProgressBar Value="{Binding Progress}" Maximum="100" Margin="0,10,0,0"
                             Visibility="{Binding ProgressVisible, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Manual override -->
                <Grid Margin="0,10,0,0"
                      Visibility="{Binding IsNotBusy, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="↑ Upload" Style="{StaticResource SecondaryButton}"
                            Command="{Binding UploadCommand}" Margin="0,0,4,0" FontSize="12"/>
                    <Button Grid.Column="1" Content="↓ Download" Style="{StaticResource SecondaryButton}"
                            Command="{Binding DownloadCommand}" Margin="4,0,0,0" FontSize="12"/>
                </Grid>

                <!-- Skip confirmation -->
                <CheckBox Margin="0,12,0,0"
                          IsChecked="{Binding SkipConfirm}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="12" Cursor="Hand">
                    Не питати підтвердження
                </CheckBox>

                <!-- Auto-sync -->
                <CheckBox Margin="0,6,0,0"
                          IsChecked="{Binding AutoSync}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="12" Cursor="Hand">
                    Авто-синк при закритті гри (фон)
                </CheckBox>

                <!-- Auto-start -->
                <CheckBox Margin="0,4,0,0"
                          IsChecked="{Binding AutoStart}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="12" Cursor="Hand">
                    Запускати з Windows
                </CheckBox>
            </StackPanel>
        </Border>

        <!-- Status -->
        <Border Grid.Row="4" VerticalAlignment="Bottom" Padding="0,4,0,0">
            <StackPanel>
                <ProgressBar IsIndeterminate="True" Margin="0,0,0,6"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
