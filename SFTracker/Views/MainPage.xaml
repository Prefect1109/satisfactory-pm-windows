<Page x:Class="SFTracker.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="Main">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: user info -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Margin="0,0,0,10">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Username}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4"
                                Padding="6,2" Margin="8,0,0,0"
                                Visibility="{Binding IsPremium, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="PREMIUM" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding StorageInfo}" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="📁" Style="{StaticResource SecondaryButton}" Padding="8,6"
                            Command="{Binding OpenSaveFolderCommand}" ToolTip="Відкрити папку сейвів"
                            Margin="0,0,6,0"/>
                    <Button Content="↺" Style="{StaticResource SecondaryButton}" Padding="8,6"
                            Command="{Binding RefreshCommand}" ToolTip="Оновити"/>
                    <Button Content="Вийти" Style="{StaticResource SecondaryButton}"
                            Command="{Binding LogoutCommand}" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- World selector -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Світ" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding Worlds}"
                          SelectedItem="{Binding SelectedWorld}"
                          DisplayMemberPath="Name"/>
            </StackPanel>
        </Border>

        <!-- Sync info -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Local -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="💾 Локально" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding LocalSaveInfo}" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Cloud -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="☁ Хмара" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding SyncStatus}" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sync actions -->
        <Border Grid.Row="3" Style="{StaticResource GlassCard}" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="⬆ Upload" Style="{StaticResource PrimaryButton}"
                            Command="{Binding UploadCommand}" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="⬇ Download" Style="{StaticResource SecondaryButton}"
                            Command="{Binding DownloadCommand}" Margin="6,0,0,0"/>
                </Grid>

                <!-- Progress -->
                <ProgressBar Value="{Binding Progress}" Maximum="100"
                             Visibility="{Binding ProgressVisible, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Padding="0,4,0,0">
            <StackPanel>
                <ProgressBar IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                             Margin="0,0,0,6"/>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
