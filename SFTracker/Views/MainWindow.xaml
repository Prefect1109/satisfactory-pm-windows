<Window x:Class="SFTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SF Tracker" Height="700" Width="460"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="16" BorderBrush="#44FFFFFF" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F0F1A" Offset="0"/>
                <GradientStop Color="#141428" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Titlebar: drag zone окремо від кнопок -->
            <Grid Grid.Row="0">
                <!-- Drag area — тільки ліва частина -->
                <Border Background="Transparent"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,80,0"
                        MouseLeftButtonDown="TitleBar_MouseDown"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="16,0" IsHitTestVisible="False">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF6B35" Offset="0"/>
                                <GradientStop Color="#FF3D00" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="SF TRACKER" Foreground="#66FFFFFF"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Window controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Width="32" Height="32" Click="Minimize_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#66FFFFFF" Cursor="Hand" ToolTip="Згорнути"
                            FontSize="14">—</Button>
                    <Button Width="32" Height="32" Click="Close_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#66FFFFFF" Cursor="Hand" ToolTip="Закрити"
                            FontSize="13">✕</Button>
                </StackPanel>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="#22FFFFFF"/>

            <!-- Content -->
            <Frame x:Name="ContentFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Border>
</Window>
