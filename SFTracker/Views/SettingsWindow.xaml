<Window x:Class="SFTracker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Налаштування" Height="340" Width="420"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="{StaticResource SurfaceBrush}"
            CornerRadius="12"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            Padding="24">
        <StackPanel>

            <!-- Titlebar -->
            <Grid Margin="0,0,0,20" MouseDown="TitleBar_MouseDown">
                <TextBlock Text="⚙️ Налаштування" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Click="Close_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Cursor="Hand"/>
            </Grid>

            <!-- Auto-Sync -->
            <Border Background="{StaticResource GlassBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="СИНХРОНІЗАЦІЯ" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <CheckBox x:Name="AutoSyncCheck" Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="13">Auto-Sync при запуску</CheckBox>
                </StackPanel>
            </Border>

            <!-- Custom Save Folder -->
            <Border Background="{StaticResource GlassBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="ПАПКА СЕЙВІВ" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SavePathBox" Grid.Column="0"
                                 Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"
                                 Padding="8,6" VerticalContentAlignment="Center"
                                 IsReadOnly="True" TextWrapping="NoWrap"/>
                        <Button Grid.Column="1" Content="Вибрати" Click="BrowseFolder_Click"
                                Margin="8,0,0,0" Padding="12,6"
                                Background="{StaticResource GlassBrush}"
                                BorderBrush="#33FFFFFF" BorderThickness="1"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="12" Cursor="Hand"/>
                    </Grid>
                    <TextBlock x:Name="PathHint" FontSize="10" Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Порожньо — автоматичний пошук"/>
                </StackPanel>
            </Border>

            <!-- Version Info -->
            <Border Background="{StaticResource GlassBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ВЕРСІЯ" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="VersionLabel" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <Button x:Name="CheckUpdateBtn" Content="Перевірити" HorizontalAlignment="Right"
                            Click="CheckUpdate_Click" Padding="12,6"
                            Background="{StaticResource GlassBrush}"
                            BorderBrush="#33FFFFFF" BorderThickness="1"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            FontSize="12" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Save Button -->
            <Button Content="Зберегти" Click="Save_Click" HorizontalAlignment="Stretch"
                    Padding="0,10" FontSize="13" FontWeight="SemiBold"
                    Background="{StaticResource AccentBrush}" BorderThickness="0"
                    Foreground="White" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </Border>
</Window>
